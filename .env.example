# Resend (https://resend.com) — used to email order confirmations
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ORDERS_FROM_EMAIL=orders@yourdomain.com
ORDERS_TO_EMAIL=you@yourdomain.com

# Meta Pixel (https://business.facebook.com/events_manager)
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# Snapchat Pixel (https://ads.snapchat.com/ → Events Manager)
NEXT_PUBLIC_SNAP_PIXEL_ID=00000000-0000-0000-0000-000000000000

# Razorpay (https://dashboard.razorpay.com/ → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
